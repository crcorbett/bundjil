{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["tooling/codec-provenance.fixture.ts"],
      "project": ["tooling/**/*.ts"]
    },
    "apps/agent": {
      "entry": [
        "agent/agent.ts",
        "agent/channels/**/*.ts",
        "agent/tools/**/*.ts",
        "test/**/*.test.ts"
      ],
      "project": ["agent/**/*.ts", "test/**/*.ts"]
    },
    "apps/codex-proxy": {
      "entry": ["api/**/*.ts", "scripts/**/*.ts", "test/**/*.test.ts"],
      "project": [
        "api/**/*.ts",
        "src/**/*.ts",
        "scripts/**/*.ts",
        "test/**/*.ts"
      ]
    }
  }
}
