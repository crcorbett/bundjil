{
  "name": "@bundjil/codex-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Private Effect HTTP proxy for Bundjil Codex subscription model access.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git",
    "directory": "apps/codex-proxy"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@bundjil/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "dev": "bun --conditions=@bundjil/source src/dev.ts",
    "proof:preview": "bun --conditions=@bundjil/source scripts/prove-preview.ts",
    "smoke-test": "bun --conditions=@bundjil/source scripts/smoke-test.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@bundjil/codex-oauth": "workspace:*",
    "@effect/platform-bun": "catalog:effect",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect",
    "@types/bun": "^1.3.14",
    "typescript": "catalog:typescript",
    "vitest": "catalog:testing"
  }
}
