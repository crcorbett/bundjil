{
  "name": "@bundjil/effect-start",
  "version": "0.1.0",
  "private": true,
  "description": "TanStack Start middleware glue for running Effect HTTP programs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git",
    "directory": "packages/effect-start"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@bundjil/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./errors": {
      "@bundjil/source": "./src/errors.ts",
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "default": "./dist/errors.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-start": "catalog:tanstack",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect",
    "typescript": "catalog:typescript",
    "vitest": "catalog:testing"
  }
}
