{
  "name": "@bundjil/codex",
  "version": "0.1.0",
  "private": true,
  "description": "Effect integration for Bundjil Codex profiles and provider runtime.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git",
    "directory": "packages/codex"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@bundjil/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "@bundjil/source": "./src/runtime.ts",
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./local": {
      "@bundjil/source": "./src/local.ts",
      "types": "./dist/local.d.ts",
      "default": "./dist/local.js"
    },
    "./testing": {
      "@bundjil/source": "./src/testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./filesystem-store": {
      "@bundjil/source": "./src/storage/filesystem.ts",
      "types": "./dist/storage/filesystem.d.ts",
      "default": "./dist/storage/filesystem.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./runtime": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "./local": {
        "types": "./dist/local.d.ts",
        "default": "./dist/local.js"
      },
      "./testing": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "./filesystem-store": {
        "types": "./dist/storage/filesystem.d.ts",
        "default": "./dist/storage/filesystem.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "import:local-profile": "bun --conditions=@bundjil/source scripts/import-local-profile.ts",
    "import:local-profile:filesystem": "bun --conditions=@bundjil/source scripts/import-local-profile-filesystem.ts",
    "login:subscription": "bun --conditions=@bundjil/source scripts/login-subscription.ts",
    "probe:empty-namespace": "bun --conditions=@bundjil/source scripts/probe-empty-namespace.ts",
    "proof:hosted-staged-refresh": "bun --conditions=@bundjil/source scripts/prove-hosted-staged-refresh.ts",
    "stage:near-expiry-profile": "bun --conditions=@bundjil/source scripts/stage-near-expiry-profile.ts",
    "proof:stored-profile": "bun --conditions=@bundjil/source scripts/prove-stored-profile.ts",
    "proof:codex-responses": "bun --conditions=@bundjil/source scripts/prove-codex-responses.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@bundjil/store": "workspace:*",
    "@effect/platform-bun": "catalog:effect",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect",
    "@types/bun": "^1.3.14",
    "typescript": "catalog:typescript",
    "vitest": "catalog:testing"
  }
}
