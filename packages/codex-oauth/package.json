{
  "name": "@bundjil/codex-oauth",
  "version": "0.1.0",
  "private": true,
  "description": "Effect service contracts for Bundjil Codex OAuth profiles.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git",
    "directory": "packages/codex-oauth"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@bundjil/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./live.layer": {
      "@bundjil/source": "./src/live.layer.ts",
      "types": "./dist/live.layer.d.ts",
      "default": "./dist/live.layer.js"
    },
    "./trusted-local.layer": {
      "@bundjil/source": "./src/trusted-local.layer.ts",
      "types": "./dist/trusted-local.layer.d.ts",
      "default": "./dist/trusted-local.layer.js"
    },
    "./mock.layer": {
      "@bundjil/source": "./src/mock.layer.ts",
      "types": "./dist/mock.layer.d.ts",
      "default": "./dist/mock.layer.js"
    },
    "./upstash-key-value-store.layer": {
      "@bundjil/source": "./src/upstash-key-value-store.layer.ts",
      "types": "./dist/upstash-key-value-store.layer.d.ts",
      "default": "./dist/upstash-key-value-store.layer.js"
    },
    "./filesystem-key-value-store.layer": {
      "@bundjil/source": "./src/filesystem-key-value-store.layer.ts",
      "types": "./dist/filesystem-key-value-store.layer.d.ts",
      "default": "./dist/filesystem-key-value-store.layer.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./live.layer": {
        "types": "./dist/live.layer.d.ts",
        "default": "./dist/live.layer.js"
      },
      "./trusted-local.layer": {
        "types": "./dist/trusted-local.layer.d.ts",
        "default": "./dist/trusted-local.layer.js"
      },
      "./mock.layer": {
        "types": "./dist/mock.layer.d.ts",
        "default": "./dist/mock.layer.js"
      },
      "./upstash-key-value-store.layer": {
        "types": "./dist/upstash-key-value-store.layer.d.ts",
        "default": "./dist/upstash-key-value-store.layer.js"
      },
      "./filesystem-key-value-store.layer": {
        "types": "./dist/filesystem-key-value-store.layer.d.ts",
        "default": "./dist/filesystem-key-value-store.layer.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "import:local-profile": "bun --conditions=@bundjil/source scripts/import-local-profile.ts",
    "import:local-profile:filesystem": "bun --conditions=@bundjil/source scripts/import-local-profile-filesystem.ts",
    "login:subscription": "bun --conditions=@bundjil/source scripts/login-subscription.ts",
    "probe:empty-namespace": "bun --conditions=@bundjil/source scripts/probe-empty-namespace.ts",
    "proof:hosted-staged-refresh": "bun --conditions=@bundjil/source scripts/prove-hosted-staged-refresh.ts",
    "stage:near-expiry-profile": "bun --conditions=@bundjil/source scripts/stage-near-expiry-profile.ts",
    "proof:stored-profile": "bun --conditions=@bundjil/source scripts/prove-stored-profile.ts",
    "proof:codex-responses": "bun --conditions=@bundjil/source scripts/prove-codex-responses.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:effect",
    "@upstash/redis": "^1.38.0",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect",
    "@types/bun": "^1.3.14",
    "typescript": "catalog:typescript",
    "vitest": "catalog:testing"
  }
}
