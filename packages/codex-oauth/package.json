{
  "name": "@bundjil/codex-oauth",
  "version": "0.1.0",
  "private": true,
  "description": "Effect service contracts for Bundjil Codex OAuth profiles.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git",
    "directory": "packages/codex-oauth"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@bundjil/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./live.layer": {
      "@bundjil/source": "./src/live.layer.ts",
      "types": "./dist/live.layer.d.ts",
      "default": "./dist/live.layer.js"
    },
    "./mock.layer": {
      "@bundjil/source": "./src/mock.layer.ts",
      "types": "./dist/mock.layer.d.ts",
      "default": "./dist/mock.layer.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./live.layer": {
        "types": "./dist/live.layer.d.ts",
        "default": "./dist/live.layer.js"
      },
      "./mock.layer": {
        "types": "./dist/mock.layer.d.ts",
        "default": "./dist/mock.layer.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "proof:codex-responses": "bun --conditions=@bundjil/source scripts/prove-codex-responses.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect",
    "typescript": "catalog:typescript",
    "vitest": "catalog:testing"
  }
}
