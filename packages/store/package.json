{
  "name": "@bundjil/store",
  "version": "0.2.0",
  "private": true,
  "description": "Provider-neutral storage contracts with explicit adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git",
    "directory": "packages/store"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@bundjil/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./memory": {
      "@bundjil/source": "./src/memory.layer.ts",
      "types": "./dist/memory.layer.d.ts",
      "default": "./dist/memory.layer.js"
    },
    "./upstash": {
      "@bundjil/source": "./src/upstash.layer.ts",
      "types": "./dist/upstash.layer.d.ts",
      "default": "./dist/upstash.layer.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./memory": {
        "types": "./dist/memory.layer.d.ts",
        "default": "./dist/memory.layer.js"
      },
      "./upstash": {
        "types": "./dist/upstash.layer.d.ts",
        "default": "./dist/upstash.layer.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:effect",
    "typescript": "catalog:typescript",
    "vitest": "catalog:testing"
  }
}
