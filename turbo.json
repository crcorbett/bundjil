{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", ".vercel/output/**", "dist/**"]
    },
    "@bundjil/agent#build": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": [
        "BUNDJIL_AGENT_MODEL_PROVIDER",
        "BUNDJIL_AGENT_MODEL",
        "BUNDJIL_EXECUTOR_MCP_URL",
        "BUNDJIL_CODEX_PROXY_BASE_URL",
        "BUNDJIL_CODEX_PROXY_CONTEXT_WINDOW_TOKENS",
        "BUNDJIL_CODEX_PROXY_INTERNAL_TOKEN",
        "BUNDJIL_CODEX_PROXY_VERCEL_BYPASS",
        "BUNDJIL_SENDBLUE_API_KEY",
        "BUNDJIL_SENDBLUE_API_SECRET",
        "BUNDJIL_SENDBLUE_WEBHOOK_SECRET",
        "BUNDJIL_SENDBLUE_ROUTING_KEY",
        "BUNDJIL_SENDBLUE_FROM_NUMBER",
        "BUNDJIL_SENDBLUE_SENDER_IDENTITIES",
        "BUNDJIL_SENDBLUE_REPLAY_STORE_URL",
        "BUNDJIL_SENDBLUE_REPLAY_STORE_TOKEN",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "BUNDJIL_SENDBLUE_REPLAY_STORE_PREFIX",
        "BUNDJIL_SENDBLUE_REPLAY_STORE_TTL_SECONDS",
        "BUNDJIL_SENDBLUE_REPLAY_STORE_LEASE_SECONDS",
        "BUNDJIL_SENDBLUE_ALLOWED_SERVICES"
      ]
    },
    "@bundjil/agent#test": {
      "env": ["BUNDJIL_EXECUTOR_MCP_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "test/**", "**/*.test.ts", "**/*.test.tsx"]
    },
    "//#check": {},
    "//#fix": {
      "cache": false
    }
  }
}
