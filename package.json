{
  "name": "bundjil",
  "private": true,
  "description": "Personal agent workspace for Vercel Eve, iMessage, email, and connected tools.",
  "keywords": [
    "agent",
    "effect",
    "eve",
    "imessage",
    "sendblue",
    "vercel"
  ],
  "homepage": "https://github.com/crcorbett/bundjil#readme",
  "bugs": {
    "url": "https://github.com/crcorbett/bundjil/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crcorbett/bundjil.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalogs": {
      "typescript": {
        "typescript": "^6.0.3"
      },
      "tanstack": {
        "@tanstack/react-start": "1.168.26"
      },
      "effect": {
        "effect": "^4.0.0-beta.74",
        "@effect/platform-bun": "4.0.0-beta.74",
        "@effect/vitest": "^4.0.0-beta.74",
        "@effect/language-service": "^0.86.2"
      },
      "testing": {
        "vitest": "^4.1.7"
      }
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "bun run check:effect-setup && turbo run build",
    "check-types": "bun run check:effect-setup && turbo run check-types",
    "check:boundaries": "bun run check:effect-setup && tsc --project tooling/tsconfig.json && bun tooling/boundary-audit.ts",
    "check:effect-setup": "effect-language-service check",
    "check:skills": "bun tooling/skill-policy-audit.ts",
    "fix": "ultracite fix --type-aware",
    "check": "ultracite check --type-aware",
    "verification": "bun run check:effect-setup && bun run check:boundaries && bun run check:skills && bun run test:boundaries && bun run check && bun run knip && bun run check-types && bun run test",
    "eve": "eve",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "prepare": "effect-language-service patch",
    "test": "turbo run test",
    "test:boundaries": "vitest run --config tooling/vitest.config.ts",
    "knip": "knip"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "catalog:effect",
    "@types/bun": "^1.3.14",
    "effect": "catalog:effect",
    "eve": "0.20.0",
    "knip": "^6.6.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6",
    "typescript": "catalog:typescript",
    "ultracite": "7.6.1",
    "vitest": "catalog:testing"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24 <25"
  },
  "packageManager": "bun@1.3.14"
}
